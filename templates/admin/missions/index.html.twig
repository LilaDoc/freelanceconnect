{% extends 'base.html.twig' %}

{% block title %}Administration — Missions{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-shield-check"></i> Tableau de bord — Missions</h1>
        <span class="badge bg-secondary fs-6">{{ missions|length }} mission{{ missions|length > 1 ? 's' : '' }}</span>
    </div>

    {# Filtres #}
    <div class="card mb-4">
        <div class="card-header bg-dark text-white">
            <i class="bi bi-funnel"></i> Filtrage avancé
        </div>
        <div class="card-body">
            {{ form_start(filterForm) }}
            <div class="row g-3">
                <div class="col-md-2">
                    {{ form_label(filterForm.client) }}
                    {{ form_widget(filterForm.client, {attr: {class: 'form-control'}}) }}
                </div>
                <div class="col-md-2">
                    {{ form_label(filterForm.freelance) }}
                    {{ form_widget(filterForm.freelance, {attr: {class: 'form-control'}}) }}
                </div>
                <div class="col-md-2">
                    {{ form_label(filterForm.dateFrom) }}
                    {{ form_widget(filterForm.dateFrom, {attr: {class: 'form-control'}}) }}
                </div>
                <div class="col-md-2">
                    {{ form_label(filterForm.dateTo) }}
                    {{ form_widget(filterForm.dateTo, {attr: {class: 'form-control'}}) }}
                </div>
                <div class="col-md-1">
                    {{ form_label(filterForm.budgetMin) }}
                    {{ form_widget(filterForm.budgetMin, {attr: {class: 'form-control'}}) }}
                </div>
                <div class="col-md-1">
                    {{ form_label(filterForm.budgetMax) }}
                    {{ form_widget(filterForm.budgetMax, {attr: {class: 'form-control'}}) }}
                </div>
                <div class="col-md-2">
                    {{ form_label(filterForm.categories) }}
                    {{ form_widget(filterForm.categories, {attr: {class: 'form-select'}}) }}
                    <small class="text-muted">Ctrl+clic pour sélection multiple</small>
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-funnel"></i> Filtrer
                </button>
                <a href="{{ path('app_admin_offres') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-x-circle"></i> Réinitialiser
                </a>
            </div>
            {{ form_end(filterForm) }}
        </div>
    </div>

    {# Tableau #}
    {% if missions is empty %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Aucune mission ne correspond aux filtres.
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Titre</th>
                        <th>Client</th>
                        <th>Freelance</th>
                        <th>Catégorie</th>
                        <th>Budget</th>
                        <th>Statut</th>
                        <th>Créée le</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for mission in missions %}
                        <tr>
                            <td class="text-muted">{{ mission.id }}</td>
                            <td><strong>{{ mission.title }}</strong></td>
                            <td>{{ mission.client.firstName }} {{ mission.client.lastName }}</td>
                            <td>
                                {% if mission.freelanceServiceProvider %}
                                    {{ mission.freelanceServiceProvider.firstName }} {{ mission.freelanceServiceProvider.lastName }}
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td>{{ mission.category.label ?? '—' }}</td>
                            <td><strong>{{ mission.budget }} €</strong></td>
                            <td>
                                {% set statusColor = {
                                    'PENDING': 'warning',
                                    'PUBLISHED': 'info',
                                    'IN_PROGRESS': 'primary',
                                    'COMPLETED': 'success',
                                    'INVOICED': 'secondary',
                                    'PAID': 'dark',
                                    'HIDDEN': 'secondary'
                                } %}
                                <span class="badge bg-{{ statusColor[mission.status.code] ?? 'secondary' }}">
                                    {{ mission.status.label }}
                                </span>
                            </td>
                            <td>{{ mission.createdAt|date('d/m/Y') }}</td>
                            <td>
                                <div class="d-flex gap-1">
                                    {% if mission.status.code == 'PENDING' %}
                                        <form action="{{ path('app_admin_offre_validate', {id: mission.id}) }}" method="post">
                                            <input type="hidden" name="_token" value="{{ csrf_token('validate' ~ mission.id) }}">
                                            <button type="submit" class="btn btn-success btn-sm">
                                                <i class="bi bi-check-lg"></i> Valider
                                            </button>
                                        </form>
                                        <form action="{{ path('app_admin_offre_reject', {id: mission.id}) }}" method="post">
                                            <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ mission.id) }}">
                                            <button type="submit" class="btn btn-warning btn-sm">
                                                <i class="bi bi-x-lg"></i> Refuser
                                            </button>
                                        </form>
                                    {% endif %}
                                    <form action="{{ path('app_admin_offre_delete', {id: mission.id}) }}" method="post"
                                          onsubmit="return confirm('Supprimer la mission « {{ mission.title }} » ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ mission.id) }}">
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Administration — Dashboard{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1 class="mb-4"><i class="bi bi-shield-check"></i> Dashboard Administration</h1>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('warning') %}
        <div class="alert alert-warning">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card text-white bg-primary h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fs-1 fw-bold">{{ totalMissions }}</div>
                        <div>Missions totales</div>
                    </div>
                    <i class="bi bi-briefcase" style="font-size: 3rem; opacity: .4;"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-dark bg-warning h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fs-1 fw-bold">{{ pendingMissions }}</div>
                        <div>En attente de validation</div>
                    </div>
                    <i class="bi bi-hourglass-split" style="font-size: 3rem; opacity: .4;"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fs-1 fw-bold">{{ totalCandidatures }}</div>
                        <div>Candidatures totales</div>
                    </div>
                    <i class="bi bi-people" style="font-size: 3rem; opacity: .4;"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body text-center py-5">
                    <i class="bi bi-briefcase text-primary" style="font-size: 3rem;"></i>
                    <h5 class="mt-3">Gestion des offres</h5>
                    <p class="text-muted">Valider, refuser ou supprimer les offres de mission.</p>
                    <a href="{{ path('app_admin_offres') }}" class="btn btn-primary">
                        <i class="bi bi-arrow-right"></i> Gérer les offres
                    </a>
                    {% if pendingMissions > 0 %}
                        <div class="mt-2">
                            <span class="badge bg-warning text-dark">
                                {{ pendingMissions }} en attente
                            </span>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

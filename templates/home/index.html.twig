{% extends 'base.html.twig' %}

{% block title %}FreelanceConnect — La plateforme freelance{% endblock %}

{% block body %}

{# Hero #}
<div class="bg-dark text-white py-5">
    <div class="container text-center py-4">
        <h1 class="display-4 fw-bold mb-3">
            <i class="bi bi-briefcase"></i> FreelanceConnect
        </h1>
        <p class="lead mb-4">
            Connectez clients et freelances pour des missions réussies.
        </p>
        {% if not app.user %}
            <a href="{{ path('app_register') }}" class="btn btn-primary btn-lg me-2">
                <i class="bi bi-person-plus"></i> Créer un compte
            </a>
            <a href="{{ path('app_login') }}" class="btn btn-outline-light btn-lg">
                <i class="bi bi-box-arrow-in-right"></i> Se connecter
            </a>
        {% elseif is_granted('ROLE_CLIENT') %}
            <a href="{{ path('app_client_dashboard') }}" class="btn btn-primary btn-lg">
                <i class="bi bi-speedometer2"></i> Accéder à mon espace
            </a>
        {% elseif is_granted('ROLE_FREELANCER') %}
            <a href="{{ path('app_freelancer_dashboard') }}" class="btn btn-primary btn-lg">
                <i class="bi bi-speedometer2"></i> Accéder à mon espace
            </a>
        {% endif %}
    </div>
</div>

{# Message de bienvenue personnalisé si connecté #}
{% if app.user %}
<div class="container mt-4">
    <div class="alert alert-success d-flex align-items-center">
        <i class="bi bi-hand-wave fs-4 me-3"></i>
        <div>
            Bienvenue, <strong>{{ app.user.firstName ?? app.user.email }}</strong> !
            {% if is_granted('ROLE_CLIENT') %}
                Gérez vos offres et trouvez le freelance idéal.
            {% elseif is_granted('ROLE_FREELANCER') %}
                Découvrez les missions disponibles et postulez.
            {% endif %}
        </div>
    </div>
</div>
{% endif %}

{# Fonctionnalités #}
<div class="container my-5">
    <h2 class="text-center mb-5">Comment ça fonctionne ?</h2>
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body py-4">
                    <i class="bi bi-file-earmark-plus text-primary" style="font-size: 2.5rem;"></i>
                    <h5 class="card-title mt-3">1. Publiez une offre</h5>
                    <p class="card-text text-muted">
                        Les clients créent des offres de mission détaillant leurs besoins, budget et délais.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body py-4">
                    <i class="bi bi-send text-success" style="font-size: 2.5rem;"></i>
                    <h5 class="card-title mt-3">2. Postulez</h5>
                    <p class="card-text text-muted">
                        Les freelances parcourent les offres et envoient leur candidature avec leur CV.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body py-4">
                    <i class="bi bi-check2-circle text-warning" style="font-size: 2.5rem;"></i>
                    <h5 class="card-title mt-3">3. Collaborez</h5>
                    <p class="card-text text-muted">
                        Le client choisit son freelance et la mission démarre. Simple et rapide.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

{# CTA bas de page #}
{% if not app.user %}
<div class="bg-light py-5">
    <div class="container text-center">
        <h3 class="mb-3">Prêt à démarrer ?</h3>
        <p class="text-muted mb-4">Rejoignez FreelanceConnect dès aujourd'hui, c'est gratuit.</p>
        <a href="{{ path('app_register') }}" class="btn btn-primary btn-lg">
            <i class="bi bi-rocket-takeoff"></i> Commencer maintenant
        </a>
    </div>
</div>
{% endif %}

{% endblock %}

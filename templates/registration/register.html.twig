{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
    <h1>Register</h1>

    {{ form_errors(registrationForm) }}

    {{ form_start(registrationForm) }}
        {{ form_row(registrationForm.userType) }}
        
        <h3>Informations personnelles</h3>
        {{ form_row(registrationForm.firstName) }}
        {{ form_row(registrationForm.lastName) }}
        
        
        <h3>Entreprise</h3>
        {{ form_row(registrationForm.company) }}
        {{ form_row(registrationForm.SIRET) }}
        
        <h3>Adresse</h3>
        {{ form_row(registrationForm.street) }}
        {{ form_row(registrationForm.postalCode) }}
        {{ form_row(registrationForm.city) }}
        {{ form_row(registrationForm.country) }}
        
        <h3>Compte</h3>
        {{ form_row(registrationForm.email) }}
        {{ form_row(registrationForm.plainPassword, {
            label: 'Mot de passe'
        }) }}
        
        {{ form_row(registrationForm.agreeTerms) }}

        <button type="submit" class="btn btn-primary">Register</button>
    {{ form_end(registrationForm) }}
{% endblock %}

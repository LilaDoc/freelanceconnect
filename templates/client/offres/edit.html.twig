{% extends 'base.html.twig' %}

{% block title %}Modifier l'offre - {{ offre.title }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Modifier l'offre de mission</h1>

    {{ form_start(form, {'attr': {'class': 'mt-4'}}) }}
        <div class="row">
            <div class="col-md-8">
                <div class="mb-3">
                    {{ form_label(form.title) }}
                    {{ form_widget(form.title, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.title) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.description) }}
                    {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.description) }}
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.budget) }}
                        <div class="input-group">
                            {{ form_widget(form.budget, {'attr': {'class': 'form-control'}}) }}
                            <span class="input-group-text">€</span>
                        </div>
                        {{ form_errors(form.budget) }}
                    </div>

                    <div class="col-md-6 mb-3">
                        {{ form_label(form.deadline) }}
                        {{ form_widget(form.deadline, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.deadline) }}
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.category) }}
                        {{ form_widget(form.category, {'attr': {'class': 'form-select'}}) }}
                        {{ form_errors(form.category) }}
                    </div>

                    <div class="col-md-6 mb-3">
                        {{ form_label(form.language) }}
                        {{ form_widget(form.language, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.language) }}
                    </div>
                </div>

                <hr>



            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg"></i> Enregistrer les modifications
            </button>
            <a href="{{ path('app_client_offres') }}" class="btn btn-secondary">
                <i class="bi bi-x-lg"></i> Annuler
            </a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}

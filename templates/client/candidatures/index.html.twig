{% extends 'base.html.twig' %}

{% block title %}{% if offre is defined %}Candidatures - {{ offre.title }}{% else %}Toutes les candidatures{% endif %}{% endblock %}

{% block body %}
<div class="container mt-4">
    {% if offre is defined %}
        <h1>Candidatures pour "{{ offre.title }}"</h1>
        <p class="text-muted">{{ offre.description|slice(0, 100) }}...</p>
    {% else %}
        <h1>Toutes les candidatures reçues</h1>
    {% endif %}

    {% if filterForm is defined %}
    <div class="card mb-4">
        <div class="card-body">
            {{ form_start(filterForm, {attr: {class: 'row g-3 align-items-end'}}) }}
                <div class="col-md-3">
                    {{ form_label(filterForm.offre) }}
                    {{ form_widget(filterForm.offre, {attr: {class: 'form-select'}}) }}
                </div>
                <div class="col-md-2">
                    {{ form_label(filterForm.status) }}
                    {{ form_widget(filterForm.status, {attr: {class: 'form-select'}}) }}
                </div>
                <div class="col-md-2">
                    {{ form_label(filterForm.dateFrom) }}
                    {{ form_widget(filterForm.dateFrom, {attr: {class: 'form-control'}}) }}
                </div>
                <div class="col-md-3">
                    {{ form_label(filterForm.freelance) }}
                    {{ form_widget(filterForm.freelance, {attr: {class: 'form-control'}}) }}
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-funnel"></i> Filtrer
                    </button>
                    <a href="{{ path('app_client_candidatures') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-x"></i>
                    </a>
                </div>
            {{ form_end(filterForm) }}
        </div>
    </div>
    {% endif %}

    {% if candidatures is empty %}
        <div class="alert alert-info">
            {% if offre is defined %}
                Aucune candidature reçue pour cette offre.
            {% else %}
                Vous n'avez pas encore reçu de candidatures sur vos offres.
            {% endif %}
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        {% if offre is not defined %}<th>Offre</th>{% endif %}
                        <th>Freelance</th>
                        <th>Date</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for candidature in candidatures %}
                        <tr>
                            {% if offre is not defined %}
                                <td>
                                    <a href="{{ path('app_client_offre_candidatures', {id: candidature.mission.id}) }}">
                                        {{ candidature.mission.title }}
                                    </a>
                                </td>
                            {% endif %}
                            <td>{{ candidature.freelance.firstName }} {{ candidature.freelance.lastName }}</td>
                            <td>{{ candidature.createdAt|date('d/m/Y') }}</td>
                            <td>
                                <span class="badge bg-{{ candidature.status.code == 'ACCEPTED' ? 'success' : (candidature.status.code == 'REFUSED' ? 'danger' : 'warning') }}">
                                    {{ candidature.status.label }}
                                </span>
                            </td>
                            <td>
                                <a href="{{ path('app_client_candidature_show', {id: candidature.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {% if offre is defined %}
        <a href="{{ path('app_client_offre_show', {id: offre.id}) }}" class="btn btn-secondary mt-3">
            <i class="bi bi-arrow-left"></i> Retour à l'offre
        </a>
    {% else %}
        <a href="{{ path('app_client_dashboard') }}" class="btn btn-secondary mt-3">
            <i class="bi bi-arrow-left"></i> Retour au tableau de bord
        </a>
    {% endif %}
</div>
{% endblock %}

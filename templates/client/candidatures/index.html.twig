{% extends 'base.html.twig' %}

{% block title %}Candidatures reçues{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Candidatures reçues</h1>

    {% if candidatures is empty %}
        <div class="alert alert-info">
            Vous n'avez pas encore reçu de candidatures sur vos offres.
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Offre</th>
                        <th>Freelancer</th>
                        <th>Date</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for candidature in candidatures %}
                        <tr>
                            <td>{{ candidature.offreMission.title }}</td>
                            <td>{{ candidature.freelancer.firstName }} {{ candidature.freelancer.lastName }}</td>
                            <td>{{ candidature.createdAt|date('d/m/Y') }}</td>
                            <td>
                                <span class="badge bg-{{ candidature.status.code == 'ACCEPTED' ? 'success' : (candidature.status.code == 'REFUSED' ? 'danger' : 'warning') }}">
                                    {{ candidature.status.label }}
                                </span>
                            </td>
                            <td>
                                <a href="#" class="btn btn-sm btn-outline-primary">Voir</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    <a href="{{ path('app_client_dashboard') }}" class="btn btn-secondary mt-3">
        <i class="bi bi-arrow-left"></i> Retour au tableau de bord
    </a>
</div>
{% endblock %}

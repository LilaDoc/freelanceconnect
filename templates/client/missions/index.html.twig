{% extends 'base.html.twig' %}

{% block title %}Mes missions en cours{% endblock %}

{% block body %}
<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_client_dashboard') }}">Dashboard</a></li>
            <li class="breadcrumb-item active">Missions en cours</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Missions en cours</h1>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% if missions is empty %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Aucune mission en cours pour le moment.
        </div>
    {% else %}
        <div class="row">
            {% for mission in missions %}
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">{{ mission.title }}</h5>
                            <p class="card-text text-muted">
                                <i class="bi bi-folder"></i> {{ mission.category.label ?? '-' }}
                            </p>
                            <p class="card-text">{{ mission.description|slice(0, 150) }}{% if mission.description|length > 150 %}...{% endif %}</p>
                            <ul class="list-unstyled">
                                <li><i class="bi bi-cash text-success"></i> <strong>{{ mission.budget }} €</strong></li>
                                <li><i class="bi bi-calendar"></i> Deadline : {{ mission.deadline|date('d/m/Y') }}</li>
                                <li><i class="bi bi-person"></i> Freelance : {{ mission.freelanceServiceProvider ? mission.freelanceServiceProvider.firstName : '-' }}</li>
                                <li><i class="bi bi-flag"></i> Statut : <span class="badge bg-warning text-dark">{{ mission.status.label ?? '-' }}</span></li>
                            </ul>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a href="{{ path('app_clientmission_show', {id: mission.id}) }}" class="btn btn-primary btn-sm">
                                <i class="bi bi-eye"></i> Voir détails
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    <a href="{{ path('app_client_dashboard') }}" class="btn btn-secondary mt-3">
        <i class="bi bi-arrow-left"></i> Retour au dashboard
    </a>
</div>
{% endblock %}

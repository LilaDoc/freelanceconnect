{% extends 'base.html.twig' %}

{% block title %}{{ mission.title }}{% endblock %}

{% block body %}
<div class="container mt-4">
    {% for message in app.flashes('success') %}
    <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
    <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_client_dashboard') }}">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_client_missions') }}">Mes missions</a></li>
            <li class="breadcrumb-item active">{{ mission.title }}</li>
        </ol>
    </nav>

    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
                <h1 class="card-title">{{ mission.title }}</h1>
                <span class="badge bg-warning text-dark fs-6">{{ mission.status.label ?? '-' }}</span>
            </div>
            <p class="text-muted">
                <i class="bi bi-folder"></i> {{ mission.category.label ?? '-' }}
                &nbsp;|&nbsp;
                <i class="bi bi-translate"></i> {{ mission.language ?? 'Non spécifié' }}
            </p>

            <hr>

            <p>{{ mission.description }}</p>

            <ul class="list-unstyled">
                <li><i class="bi bi-cash text-success"></i> <strong>Budget : {{ mission.budget }} €</strong></li>
                <li><i class="bi bi-calendar"></i> Deadline : {{ mission.deadline|date('d/m/Y') }}</li>
                <li>
                    <i class="bi bi-person-check"></i> Freelance assigné :
                    <strong>{{ mission.freelanceServiceProvider ? mission.freelanceServiceProvider.firstName : 'Non assigné' }}</strong>
                </li>
            </ul>
            
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <a href="{{ path('app_client_missions') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Retour aux missions
        </a>
        {% if mission.status.code == 'IN_PROGRESS' %}
        <form method="post" action="{{ path('app_clientmission_close', {id: mission.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('close' ~ mission.id) }}">
            <button type="submit" class="btn btn-success">
                <i class="bi bi-check-circle"></i> Clôturer la mission
            </button>
        </form>
        {% endif %}
        {% if mission.hasFirstPayment and not mission.firstPaymentActed %}
        <form method="post" action="{{ path('app_client_mission_firstpayment_acte', {id: mission.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('close' ~ mission.id) }}">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-cash-coin"></i> Acter le premier paiement ({{ mission.firstPaymentValue }} €)
            </button>
        </form>
        {% endif %}
    </div>
</div>
{% endblock %}
